  <string key="IdleCount">
<!-- 0 - player's name -->
<!-- 1 - idle count -->
<!--New strings 7th of July-->
<!--If you are translating werewolf in a non-standard mode (eg. Mafia, PokГ©mon and similar) please put the role and the emoji in front of the string.
  For example in Mafia, AboutMason would be:
  Caporegime рҹ‘·\nYou are a caporegime blah blah
